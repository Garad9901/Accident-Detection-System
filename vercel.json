{
  "version": 2,
  "framework": "vite",
  "installCommand": "npm install && npm run install:all",
  "buildCommand": "npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://accident-detection-system-web7.onrender.com/api/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "wss://accident-detection-system-web7.onrender.com/ws/:path*"
    }
  ]
}
